# 실제 값은 .env 에 작성 (.env 는 git 무시 대상)

# App
PORT=3000

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=issue_analyst
MYSQL_PORT=3306
# Prisma 연결 문자열 (mysql://유저:비번@호스트:포트/DB)
DATABASE_URL="mysql://root:root@localhost:3306/issue_analyst"

# Qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL="http://localhost:6333"

# Redis
REDIS_PORT=6379
REDIS_URL="redis://localhost:6379"

# OpenAI (임베딩: text-embedding-3-small)
OPENAI_API_KEY=
