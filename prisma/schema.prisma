// Prisma 스키마 (중앙 관리)
// 변경 후 반드시 `npx prisma migrate dev` 로 마이그레이션 생성

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// QA 이슈 (분석 대상 핵심 엔티티) — 초기 baseline, 이후 마이그레이션으로 진화
model Issue {
  id        Int      @id @default(autoincrement())
  title     String
  body      String   @db.Text
  category  String? // classify Tool이 채우는 분류값
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
