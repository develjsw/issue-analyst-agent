generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Issue {
  id        Int      @id @default(autoincrement())
  title     String
  body      String   @db.Text
  category  String? // IssueCategory
  status    String   @default("OPEN") // IssueStatus
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("issue") // OS 대소문자 회피
}

model Document {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(255)
  content   String   @db.LongText
  type      String   @db.VarChar(50) // DocumentType
  source    String?  @db.VarChar(500)
  isIndexed Boolean  @default(false) // Qdrant 인덱싱 여부
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isIndexed])
  @@map("document") // OS 대소문자 회피
}
